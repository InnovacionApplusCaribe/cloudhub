# Potree Cloud Hub Configuration
# Copy this to .env or .env.local and fill in your values

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# PotreeConverter Binary Path
# ============================================
# Can be either:
# 1. Directory path (code auto-detects binary based on OS):
#    - Windows: appends /PotreeConverter.exe
#    - Linux: appends /linux/PotreeConverter
#    Example: C:\path\to\PotreeConverter
#
# 2. Full binary path:
#    - Windows: C:\path\to\PotreeConverter\PotreeConverter.exe
#    - Linux: /path/to/PotreeConverter/linux/PotreeConverter
#
# Leave empty to use default paths in code
POTREE_CONVERTER_PATH=

# ============================================
# Azure Blob Storage Configuration
# ============================================
# Get connection string from Azure Portal:
# Storage Account → Access Keys → Connection string
AZURE_STORAGE_CONNECTION_STRING=2v96MVNtBtmT4byzVCrdd3sxA3aiCBxdffdo23vxVi66cpNcySAOFTEfRamuYgE+iQJlJ4Ai0blY+AStDyLbBw==

# Container names (auto-created if don't exist)
AZURE_RAW_CONTAINER_NAME=cloudhub
AZURE_CONVERTED_CONTAINER_NAME=cloudhub-converter
AZURE_UPLOADS_TEMP_CONTAINER_NAME=uploads-container-temp

# ============================================
# Notes for .env file:
# - DO NOT commit this file to git (it's in .gitignore)
# - Use .env.local for local development
# - Use App Service Configuration for production
# ============================================
